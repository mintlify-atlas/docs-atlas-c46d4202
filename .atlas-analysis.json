  "keyFeatures": [
    "Personal portfolio showcasing projects and work experience",
    "Blog with MDX-based articles",
    "Real-time Discord presence status via lantern.rest API",
    "Live Spotify track display when listening",
    "Dark/light mode with warm color palette",
    "View transitions for smooth page navigation",
    "Rybbit analytics integration",
    "Zod-based environment variable validation"
  ],
  "publicApiSurface": [
    "GET https://lantern.rest/api/v1/users/:userId — Discord presence status",
    "generateMetadata(options) — Next.js metadata generation utility",
    "cn(...classes) — Tailwind class merging utility",
    "getRelativeTime(timestamp) — Human-readable relative time formatter",
    "validateEnvironmentVariables() — Zod environment variable validator"
  ]
