            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Self-Hosting",
            "pages": ["self-hosting/prerequisites", "self-hosting/configuration", "self-hosting/deployment"]
          }
        ]
      },
      {
        "tab": "Features",
        "groups": [
          {
            "group": "Core Features",
            "pages": ["features/portfolio", "features/blog", "features/discord-status"]
          },
          {
            "group": "Components",
            "pages": ["components/overview", "components/discord-status", "components/inline-quote", "components/avatar"]
          }
        ]
      },
      {
        "tab": "Development",
        "groups": [
          {
            "group": "Contributing",
            "pages": ["development/contributing", "development/code-of-conduct", "development/changelog"]
          },
          {
            "group": "Configuration",
            "pages": ["development/environment-variables", "development/analytics"]
          }
        ]
      }
    ]
